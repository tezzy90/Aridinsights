{
    "name": "aridinsights-monorepo",
    "private": true,
    "volta": {
        "node": "20.20.0",
        "npm": "10.8.2"
    },
    "workspaces": [
        "apps/*",
        "services/*",
        "packages/*"
    ],
    "engines": {
        "node": ">=20 <21"
    },
    "scripts": {
        "lint": "npm run lint -w apps/web-main",
        "prepare": "command -v husky >/dev/null 2>&1 && husky install || echo \"husky not installed, skipping\"",
        "doctor": "node scripts/doctor.mjs",
        "preflight": "bash scripts/preflight.sh",
        "prompts:discover": "node scripts/prompt_discovery.mjs",
        "prompts:sync": "python3 scripts/prompt_extract.py",
        "dev:docs": "npm -w apps/docs-portal run dev",
        "index:docs": "npm -w apps/docs-portal run index"
    },
    "devDependencies": {
        "husky": "^9.0.0"
    }
}