rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Customers: users can read their own profile (optional)
    match /customers/{customerId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == customerId);
      allow write: if isAdmin();
    }

    // Orders: only admins by default; creation should happen via server webhook
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Jobs + evidence + context packs are server-side only
    match /jobs/{jobId} {
      allow read, write: if isAdmin();
    }

    match /contextPacks/{contextPackId} {
      allow read, write: if isAdmin();
    }

    match /evidenceLogs/{evidenceLogId} {
      allow read, write: if isAdmin();
    }

    match /quarantine/{quarantineId} {
      allow read, write: if isAdmin();
    }

    match /coverageLedger/{coverageId} {
      allow read: if isAdmin(); // later: read-only public excerpt possible
      allow write: if isAdmin();
    }

    match /prompts/{promptId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /promptRuns/{runId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
